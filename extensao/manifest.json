{
  "manifest_version": 3,
  "name": "Betting Userbot",
  "version": "1.0",
  "description": "Executa apostas na Bet365 a partir de sinais do Telegram",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "alarms", "debugger"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://*.bet365.bet.br/*",
    "*://bet365.bet.br/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.bet365.bet.br/*",
        "*://bet365.bet.br/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Betting Userbot"
  }
}
